{
  "name": "opencode-tui-for-vscode",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.5.6",
  "publisher": "opencode-tui-unofficial",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ilgizar-valiullin/opencode-tui-for-vscode.git"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "opencode-tui",
          "title": "%viewContainer.title%",
          "icon": "images/dark-theme.svg"
        }
      ]
    },
    "views": {
      "opencode-tui": [
        {
          "type": "webview",
          "id": "opencode-tui.view",
          "name": "%view.terminal.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "opencode-tui-unofficial.focusView",
        "title": "%cmd.focusView.title%",
        "icon": {
          "light": "images/light-theme.svg",
          "dark": "images/dark-theme.svg"
        }
      },
      {
        "command": "opencode-tui-unofficial.openTerminal",
        "title": "%cmd.openTerminal.title%"
      },
      {
        "command": "opencode-tui-unofficial.openTab",
        "title": "%cmd.openTab.title%"
      },
      {
        "command": "opencode-tui-unofficial.stopServer",
        "title": "%cmd.stopServer.title%"
      },
      {
        "command": "opencode-tui-unofficial.attachFile",
        "title": "%cmd.attachFile.title%"
      },
      {
        "command": "opencode-tui-unofficial.attachFileContext",
        "title": "%cmd.attachFile.title%"
      },
      {
        "command": "opencode-tui-unofficial.toggleFocus",
        "title": "%cmd.toggleFocus.title%"
      }
    ],
    "keybindings": [
      {
        "command": "opencode-tui-unofficial.toggleFocus",
        "key": "ctrl+shift+'",
        "when": "!editorFocus"
      },
      {
        "command": "opencode-tui-unofficial.toggleFocus",
        "key": "ctrl+shift+'",
        "when": "editorFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "opencode-tui-unofficial.focusView",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "opencode-tui-unofficial.attachFileContext",
          "group": "9_opencode"
        }
      ],
      "editor/title/context": [
        {
          "command": "opencode-tui-unofficial.attachFile",
          "group": "3_opencode",
          "when": "resourceScheme == file"
        }
      ],
      "explorer/context": [
        {
          "command": "opencode-tui-unofficial.attachFile",
          "group": "5_opencode"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "opencode-tui-unofficial.opencodePath": {
          "type": "string",
          "default": "opencode",
          "description": "%cfg.opencodePath.desc%"
        },
        "opencode-tui-unofficial.serverPort": {
          "type": "integer",
          "default": 0,
          "description": "%cfg.serverPort.desc%"
        },
        "opencode-tui-unofficial.leaderChords": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]$"
          },
          "default": [],
          "description": "%cfg.leaderChords.desc%"
        },
        "opencode-tui-unofficial.ctrlASelectAll": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.ctrlASelectAll.desc%"
        },
        "opencode-tui-unofficial.enterSendsMessage": {
          "type": "boolean",
          "default": true,
          "description": "%cfg.enterSendsMessage.desc%"
        },
        "opencode-tui-unofficial.orphanCleanup.startupScan": {
          "type": "boolean",
          "default": {
            "windows": true,
            "default": false
          },
          "description": "%cfg.orphanCleanup.startupScan.desc%"
        },
        "opencode-tui-unofficial.orphanCleanup.watchdog": {
          "type": "boolean",
          "default": {
            "windows": true,
            "default": false
          },
          "description": "%cfg.orphanCleanup.watchdog.desc%"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "node test/smoke.mjs",
    "lint": "eslint src/ test/ esbuild.mjs eslint.config.mjs",
    "package": "node esbuild.mjs && vsce package"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.84.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vscode/vsce": "^3.0.0",
    "@xterm/xterm": "^5.5.0",
    "esbuild": "^0.24.0",
    "eslint": "^10.6.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.10.0",
    "node-pty": "^1.1.0"
  }
}
