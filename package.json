{
  "name": "opencode-tui-unofficial",
  "displayName": "OpenCode TUI Integration",
  "description": "OpenCode TUI embedded in VS Code with proper keyboard handling for non-Latin layouts",
  "version": "1.1.0",
  "publisher": "opencode-tui-unofficial",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ilgizar-valiullin/opencode-tui-integration-unofficial.git"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "opencode-tui",
          "title": "OpenCode",
          "icon": "images/dark-theme.svg"
        }
      ]
    },
    "views": {
      "opencode-tui": [
        {
          "type": "webview",
          "id": "opencode-tui.view",
          "name": "Terminal"
        }
      ]
    },
    "commands": [
      {
        "command": "opencode-tui-unofficial.focusView",
        "title": "OpenCode",
        "icon": {
          "light": "images/light-theme.svg",
          "dark": "images/dark-theme.svg"
        }
      },
      {
        "command": "opencode-tui-unofficial.openTerminal",
        "title": "OpenCode: Open Terminal"
      },
      {
        "command": "opencode-tui-unofficial.openTab",
        "title": "OpenCode: Open Terminal (Tab)"
      },
      {
        "command": "opencode-tui-unofficial.stopServer",
        "title": "OpenCode: Stop Server"
      },
      {
        "command": "opencode-tui-unofficial.attachFile",
        "title": "OpenCode: Attach File"
      },
      {
        "command": "opencode-tui-unofficial.attachFileContext",
        "title": "OpenCode: Attach File"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "opencode-tui-unofficial.focusView",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "opencode-tui-unofficial.attachFileContext",
          "group": "9_opencode"
        }
      ],
      "editor/title/context": [
        {
          "command": "opencode-tui-unofficial.attachFile",
          "group": "3_opencode",
          "when": "resourceScheme == file"
        }
      ],
      "explorer/context": [
        {
          "command": "opencode-tui-unofficial.attachFile",
          "group": "5_opencode"
        }
      ]
    },
    "configuration": {
      "title": "OpenCode TUI Integration",
      "properties": {
        "opencode-tui-unofficial.opencodePath": {
          "type": "string",
          "default": "opencode",
          "description": "Path to opencode. E.g. 'C:/Users/ilgiz/AppData/Local/OpenCode/opencode.exe', 'opencode.cmd', or just 'opencode'."
        },
        "opencode-tui-unofficial.serverPort": {
          "type": "integer",
          "default": 0,
          "description": "Port for opencode server. 0 = random available port."
        },
        "opencode-tui-unofficial.leaderChords": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]$"
          },
          "default": [],
          "description": "Leader chord characters to intercept (e.g. [\"n\",\"m\",\"l\"]). Empty = use tui.json or built-in defaults."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs && vsce package"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.84.0",
    "@vscode/vsce": "^3.0.0",
    "@xterm/xterm": "^5.5.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.10.0",
    "node-pty": "^1.1.0"
  }
}
